# Copia este archivo como .streamlit/secrets.toml SOLO en tu computadora local.
# En Streamlit Cloud, pega estos valores en App > Settings > Secrets.

[connections.gsheets]
spreadsheet = "URL_DE_TU_GOOGLE_SHEET"
# Si usas Google Sheet público/compartido por link puede bastar el URL.
# Si usas cuenta de servicio privada, agrega aquí el bloque completo de credenciales según Streamlit.
